# =============================================================
# client-workbook-dashboard — environment variable reference
# =============================================================
# This file lists every env var the application code reads, with
# placeholder/blank values only — NEVER commit real secrets here.
# Real values live in the project's Vercel Environment Variables.
#
# Secrets (anything ending in _TOKEN, _KEY, _SECRET, plus
# CRON_SECRET and SHARED_INTEGRATION_BEARER_TOKEN) belong on the
# Production scope in Vercel. CRON_SECRET is Production-only —
# the cron should not run on preview/development.
#
# Grouped by integration. Each var has a one-line comment on what
# it's for. Generated from a process.env grep of the codebase; see
# the chore/env-example-audit PR description for the diff vs the
# prior version (which still listed the GOOGLE_SERVICE_ACCOUNT_*
# pair that was never read by code).

# =============================================================
# Basecamp (OAuth + active tokens)
# =============================================================
# Client credentials from the 37signals OAuth app. Used only on the
# /api/auth/callback redirect to exchange the initial code.
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=
BASECAMP_REDIRECT_URI=https://your-deployment.vercel.app/api/auth/callback

# Account id (37signals workspace id, numeric). The poller and all
# data fetches scope to this account.
BASECAMP_ACCOUNT_ID=

# Active access + refresh tokens. The app rotates these via the
# 37signals token endpoint and writes the new pair back to Vercel
# env via VERCEL_API_TOKEN below. Seed once after the OAuth dance.
BASECAMP_ACCESS_TOKEN=
BASECAMP_REFRESH_TOKEN=

# =============================================================
# GitHub (commit synced data back to the repo for auto-redeploy)
# =============================================================
# Fine-grained PAT with Contents:Read+Write on this repo only.
GITHUB_TOKEN=
# Full repo path, e.g. "JLcilliers/client-workbook-dashboard".
# Defaults to JLcilliers/client-workbook-dashboard if unset.
GITHUB_REPO=

# =============================================================
# Vercel (write-back for rotated Basecamp tokens)
# =============================================================
# Token with envs:write scope on the target project.
VERCEL_API_TOKEN=
# Numeric project id, prj_-prefixed, from Vercel project Settings.
VERCEL_PROJECT_ID=
# Team id, team_-prefixed. Required when the project lives in a team.
VERCEL_TEAM_ID=

# =============================================================
# Google OAuth (GSC + GA4 data fetches)
# =============================================================
# OAuth client from Google Cloud Console; same client used for both
# GSC and GA4 because both scopes are added to the consent screen.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Long-lived refresh token from one-time admin consent flow. The
# code exchanges this for short-lived access tokens on each request.
GOOGLE_OAUTH_REFRESH_TOKEN=

# =============================================================
# Google Sheets (Content tab data source)
# =============================================================
# Spreadsheet id from the sheet URL between /d/ and /edit.
GOOGLE_SHEET_ID=
# Numeric sheet (tab) id within the spreadsheet — the gid= URL param.
GOOGLE_SHEET_GID=

# =============================================================
# Anthropic (chat, ai-summary, meeting-prep, task-summaries)
# =============================================================
# Read implicitly by `new Anthropic()` from the SDK. Required for
# any AI-powered route to function.
ANTHROPIC_API_KEY=

# =============================================================
# Admin auth (the /admin gate + team-assignments writes)
# =============================================================
# Plaintext password compared by /api/admin/auth.
ADMIN_PASSWORD=
# Long random string (>=32 chars) used to HMAC the admin session cookie.
ADMIN_SESSION_SECRET=

# =============================================================
# Supabase (Phase 1 onboarding-tab read + Phase 3 cron writes)
# =============================================================
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================
# Cron (Phase 3 Basecamp-to-Workbook poller)
# =============================================================
# Bearer that Vercel's scheduled cron passes to /api/cron/basecamp-poller.
# Set on Production scope ONLY — preview/dev runs of the cron are
# not wanted.
CRON_SECRET=
# Bearer that the workbook cron sends to the onboarding repo's
# /api/admin/onboarding/create endpoint. Must match the same-named
# var on the onboarding repo.
SHARED_INTEGRATION_BEARER_TOKEN=

# =============================================================
# Go High Level (GHL pivot — webhook receiver)
# =============================================================
# Shared secret for the GHL Pipeline-Stage-Changed workflow's
# Custom-Webhook action. The workflow sends `Authorization: Bearer
# <this value>` to /api/webhooks/ghl/opportunity-onboarded; the
# receiver compares exact-equal and 401s on any mismatch. Set on
# Production scope only — preview/dev environments don't host a
# live workflow. Rotate by generating a fresh `openssl rand -hex
# 32` and pasting into both Vercel and the GHL workflow header.
GHL_WEBHOOK_BEARER=

# =============================================================
# Sync (legacy manual /api/sync trigger)
# =============================================================
# Bearer that protects the manual data-refresh endpoint.
SYNC_API_KEY=

# =============================================================
# Public share links (/share/<token>)
# =============================================================
# Long random string (>=16 chars). Used to sign share-token URLs.
# Rotating this invalidates every share URL handed out.
SHARE_SECRET=

# =============================================================
# Vercel Blob (team-assignments storage)
# =============================================================
# Auto-provided by Vercel Blob in Production/Preview. Required for
# local dev only if you want to test the team-assignments write path.
BLOB_READ_WRITE_TOKEN=

# =============================================================
# Optional: local utility scripts (NOT required by the Next app)
# =============================================================
# Only used by capture-brightlocal-grids.js, a one-off scraper at the
# repo root. Safe to leave unset for normal dev/deploy.
BRIGHTLOCAL_EMAIL=
BRIGHTLOCAL_PASSWORD=
